&lt;span style="color:#a90d91">this&lt;/span>&lt;span style="color:#000">.&lt;/span>&lt;span style="color:#836c28">key&lt;/span> &lt;span style="color:#000">=&lt;/span> &lt;span style="color:#000">key&lt;/span>&lt;span style="color:#000">;&lt;/span>
