&lt;span style="color:#000">res&lt;/span> &lt;span style="color:#000">=&lt;/span> &lt;span style="color:#000">Math&lt;/span>&lt;span style="color:#000">.&lt;/span>&lt;span style="color:#836c28">max&lt;/span>&lt;span style="color:#000">(&lt;/span>&lt;span style="color:#000">res&lt;/span>&lt;span style="color:#000">,&lt;/span> &lt;span style="color:#000">Arrays&lt;/span>&lt;span style="color:#000">.&lt;/span>&lt;span style="color:#836c28">stream&lt;/span>&lt;span style="color:#000">(&lt;/span>&lt;span style="color:#000">account&lt;/span>&lt;span style="color:#000">).&lt;/span>&lt;span style="color:#836c28">sum&lt;/span>&lt;span style="color:#000">());&lt;/span>
&lt;span style="color:#000">}&lt;/span>
&lt;span style="color:#a90d91">return&lt;/span> &lt;span style="color:#000">res&lt;/span>&lt;span style="color:#000">;&lt;/span>
